{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile data including plan, credits, and favorites.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "name": { "type": "string", "description": "User full name" },
        "plan": { "type": "string", "enum": ["free", "pro", "admin"], "description": "Subscription plan" },
        "credits": { "type": "number", "description": "Available credits" },
        "favorites": { "type": "array", "description": "List of favorite prompt IDs" },
        "dailyGenerations": { "type": "number", "description": "Number of generations today" },
        "lastGenerationDate": { "type": "string", "format": "date-time", "description": "ISO string of last generation" },
        "isLifetime": { "type": "boolean", "description": "Whether user has lifetime access" }
      },
      "required": ["uid", "email", "plan", "credits"]
    },
    "PromptStats": {
      "title": "Prompt Stats",
      "description": "Statistics for prompts such as view counts.",
      "type": "object",
      "properties": {
        "views": { "type": "number", "description": "Number of views" }
      },
      "required": ["views"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/prompt_stats/{promptId}": {
      "schema": "PromptStats",
      "description": "Prompt statistics documents."
    }
  }
}
